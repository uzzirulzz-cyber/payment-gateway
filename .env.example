# Neon PostgreSQL (serverless Postgres)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
DIRECT_URL=postgresql://user:password@host/dbname?sslmode=require&channel_binding=require

# JazzCash credentials.
# Set JAZZCASH_SANDBOX=false ONLY when you have production credentials
# (different from sandbox creds) and your merchant account is approved
# for live payments.
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=
JAZZCASH_SANDBOX=true
JAZZCASH_RETURN_URL=http://localhost:3000/api/jazzcash/return

# Public app URL (used to build absolute return URL when JAZZCASH_RETURN_URL not set).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# z-ai-web-dev-sdk (for the AI description helper).
ZAI_API_KEY=
