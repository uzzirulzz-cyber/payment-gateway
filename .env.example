# ──────────────────────────────────────────────────────────────────────────
#  PlayBeat Digital — Environment Variables (OPTIONAL)
# ──────────────────────────────────────────────────────────────────────────
#
# All values are hardcoded in src/lib/env.ts — you do NOT need this file.
#
# This file exists only if you want to OVERRIDE the hardcoded values without
# editing code. Copy to .env and change what you need:
#
#   cp .env.example .env
#
# Any env var set here takes priority over the hardcoded values in env.ts.
#

# MongoDB Atlas (hardcoded: playbeat cluster)
# MONGODB_URI=mongodb+srv://user:pass@cluster/db?appName=app

# JazzCash (hardcoded: MC828331, live mode)
# JAZZCASH_MERCHANT_ID=
# JAZZCASH_PASSWORD=
# JAZZCASH_INTEGRITY_SALT=
# JAZZCASH_SANDBOX=false
# JAZZCASH_DEMO_MODE=false
# JAZZCASH_RETURN_URL=

# Email (hardcoded: empty = uses Ethereal test accounts)
# Set these to send real emails via SMTP:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=

# z-ai-web-dev-sdk
# ZAI_API_KEY=
