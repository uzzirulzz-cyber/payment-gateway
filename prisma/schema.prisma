// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id               String   @id @default(cuid())
  txnRefNo         String   @unique
  amount           Float
  description      String
  customerEmail    String?
  customerName     String?
  customerPhone    String?
  status           String   @default("pending") // pending | paid | failed | cancelled | refunded
  responseCode     String?
  responseMessage  String?
  paymentMethod    String?
  transactionId    String? // JazzCash pp_TxnRefNo (different from our ref) / pp_RetreivalReferenceNumber
  rawResponse      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

/// Branding + theme settings. One row per restore point.
/// The row with isDefault=true is the active configuration.
model Setting {
  id             String   @id @default(cuid())
  name           String   @unique // e.g. "default", "christmas-2026"
  label          String   // human-friendly, e.g. "Default"
  isDefault      Boolean  @default(false)
  logoPath       String   @default("/playbeat-logo.png")
  backgroundPath String   @default("/playbeat-bg.jpg")
  primaryColor   String   @default("#1e3a8a") // blue
  accentColor    String   @default("#3b82f6") // lighter blue
  heroTitle      String   @default("PlayBeat")
  heroTagline    String   @default("Premium digital products delivered instantly.")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
